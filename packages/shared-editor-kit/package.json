{
  "name": "@campus/shared-editor-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Editor Kit (SEK) — public TypeScript interface consumed by Teacher Web App (TWA) and Student Desktop App (SDA). See docs/Campus platform architecture.md Section 3 (SEK-01..05) and docs/campus-platform-work-division.md Wave 1.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./code-editor": {
      "types": "./src/code-editor/index.ts",
      "default": "./src/code-editor/index.ts"
    },
    "./document-viewer": {
      "types": "./src/document-viewer/index.ts",
      "default": "./src/document-viewer/index.ts"
    },
    "./notes": {
      "types": "./src/notes/index.ts",
      "default": "./src/notes/index.ts"
    },
    "./image-search": {
      "types": "./src/image-search/index.ts",
      "default": "./src/image-search/index.ts"
    },
    "./types": {
      "types": "./src/types/common.ts",
      "default": "./src/types/common.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc",
    "build": "tsc -p tsconfig.base.json",
    "test": "tsc"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "campus-platform",
    "sek",
    "shared-editor-kit",
    "twa",
    "sda"
  ],
  "license": "UNLICENSED"
}
